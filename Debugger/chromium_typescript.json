{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "chrome",
            "request": "launch",
            "name": "Launch Chromium (4201)",
            "runtimeExecutable": "/snap/bin/chromium",
            "url": "http://localhost:4201",
            "webRoot": "${workspaceFolder}",
            "userDataDir": "${env:HOME}/chromium-debug-profile",
            "sourceMaps": true,
            "sourceMapPathOverrides": {
                "webpack:/*": "*",
                "/./*": "${webRoot}/*",
                "/src/*": "${webRoot}/*",
                "/*": "*",
                "/./~/*": "${webRoot}/node_modules/*"
            }
        }
    ]
}
